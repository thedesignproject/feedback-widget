{
  "name": "@tosses/feedback-widget",
  "version": "0.3.4",
  "description": "Visual feedback widget for React apps",
  "type": "module",
  "main": "dist/feedback-widget.umd.js",
  "module": "dist/feedback-widget.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/feedback-widget.es.js",
      "require": "./dist/feedback-widget.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --project tsconfig.check.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vercel/node": "^5.7.12",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.2"
  }
}
